# Copy this file to .env and fill your real values.

# ============== MAILTRAP CONFIGURATION (Recommended for Forgot-Password OTP) ==============
# Get SMTP credentials from https://mailtrap.io -> Email Testing -> SMTP Settings
# You can use either SMTP_* (preferred, generic) or MAILTRAP_* aliases.
SMTP_EMAIL=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_SERVER=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=15
SMTP_SENDER_NAME=Project Aegis Ghost
# Optional sender address shown in "From" (if omitted, SMTP_EMAIL is used)
# SMTP_SENDER_EMAIL=no-reply@aegis-ghost.local

# Optional Mailtrap aliases (same values as above; backend supports both)
# MAILTRAP_USERNAME=your_mailtrap_username
# MAILTRAP_PASSWORD=your_mailtrap_password
# MAILTRAP_HOST=smtp.mailtrap.io
# MAILTRAP_PORT=2525
# MAILTRAP_SENDER_NAME=Project Aegis Ghost
# MAILTRAP_SENDER_EMAIL=no-reply@aegis-ghost.local

# Optional: Mailtrap Sending API (token-based, no SMTP username/password needed)
# MAILTRAP_USE_API=true
# MAILTRAP_API_TOKEN=your_mailtrap_api_token
# MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
# MAILTRAP_FROM_NAME=Project Aegis Ghost
# MAILTRAP_FROM_EMAIL=no-reply@aegis-ghost.local
# MAILTRAP_CATEGORY=otp

# ============== GMAIL CONFIGURATION (Alternative) ==============
# Gmail requirement: enable 2-Step Verification and use a 16-char App Password.
# To use Gmail instead, uncomment and configure:
# SMTP_EMAIL=yourgmail@gmail.com
# SMTP_PASSWORD=your_16_char_gmail_app_password
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TIMEOUT=15
# SMTP_SENDER_NAME=Project Aegis Ghost

# ============== MOCK MODE (For testing without email) ==============
# Set SMTP_PASSWORD=MOCK to print emails to console instead of sending

# ============== PRODUCTION CONFIGURATION (Item 9) ==============
# Rate limiting
RATE_LIMIT_PER_MIN=120

# Upload limits
MAX_UPLOAD_MB=15

# Data retention (days)
DATA_RETENTION_DAYS=30

# Output encryption key (change in production!)
OUTPUT_ENCRYPTION_KEY=your-secure-key-here

# AI Providers (optional)
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# PUTER_API_KEY=your-puter-api-key
# PUTER_IMAGE_ENDPOINT=https://api.puter.com/v1/images/generations
# PUTER_IMAGE_MODEL=sdxl
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
# OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=http://localhost
# OPENROUTER_X_TITLE=Project Aegis Ghost
# OPENROUTER_MAX_OUTPUT_TOKENS=512
# GROQ_API_KEY=your-groq-api-key
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GROQ_SECURITY_MODEL=llama-3.3-70b-versatile
# OPENROUTER_SECURITY_MODEL=openai/gpt-4o-mini
# AI_HTTP_RETRIES=2
# AI_HTTP_BACKOFF_SEC=0.8
# GENAI_IMAGE_MODEL=gemini-2.0-flash-exp
# OPENAI_IMAGE_MODEL=gpt-image-1

# DeepAI Image Generation (https://deepai.org/)
# DEEPAI_API_KEY=your-deepai-api-key
# PEXELS_API_KEY=your-pexels-api-key
# RAPHAEL_API_KEY=your-raphael-api-key
# RAPHAEL_API_URL=https://evolink.ai/z-image-turbo
# Optional aliases also supported:
# PEXELS_TOKEN=your-pexels-api-key
# RAPHAEL_TOKEN=your-raphael-api-key
# LEONARDO_API_KEY=your-leonardo-api-key
# LEONARDO_MODEL_ID=aa77f04e-3eec-4034-9c07-d0f619684628
# DEEPAI_MODEL=text2img  # Options: text2img, stable-diffusion, waifu

# Advanced crypto features (Shamir/Russian Doll/advanced stego)
# ENABLE_ADVANCED_CRYPTO=false
