{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "aptPkgs": [
      "cmake",
      "g++",
      "make",
      "build-essential",
      "portaudio19-dev",
      "libgl1-mesa-glx",
      "libglib2.0-0"
    ]
  },
  "deploy": {
    "startCommand": "uvicorn server:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/api/health/live",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

